# Node
/node_modules

# Laravel (DO NOT ignore required directories)
public/hot
public/storage
storage/*.key
storage/logs
storage/framework/cache/data

# Keep these directories (use .gitkeep)
!storage/framework/cache/
!storage/framework/sessions/
!storage/framework/views/
!bootstrap/cache/

# Ignore files inside them, but keep the folders
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*

# Allow .gitkeep
!storage/framework/cache/.gitkeep
!storage/framework/sessions/.gitkeep
!storage/framework/views/.gitkeep
!bootstrap/cache/.gitkeep

# Composer
/vendor
/src/vendor/
/src/.composer/

# Environment
.env
.env.backup

# PHPUnit
.phpunit.result.cache

# Docker
docker/mysql/data/

# IDE
/.idea
/.vscode

# Misc
npm-debug.log
yarn-error.log

# Homestead
Homestead.json
Homestead.yaml
